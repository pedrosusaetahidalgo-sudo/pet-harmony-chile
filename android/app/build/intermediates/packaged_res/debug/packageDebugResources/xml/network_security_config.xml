<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Base config: Trust system CAs and allow cleartext for local development -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- Domain-specific config for Supabase and Lovable -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">supabase.co</domain>
        <domain includeSubdomains="true">lovableproject.com</domain>
        <domain includeSubdomains="true">pawfriend.cl</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
    
    <!-- Debug config for local development (remove for production) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
